# FanMind staging template — placeholders only, never copy Production secrets or customer data.
FANMIND_RUNTIME_ENVIRONMENT=staging
NEXT_PUBLIC_APP_URL=https://staging.fanmind.example
NEXT_PUBLIC_SITE_URL=https://staging.fanmind.example
NEXT_PUBLIC_SUPABASE_URL=https://stagingprojectref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace_with_staging_anon_key
SUPABASE_SERVICE_ROLE_KEY=replace_with_staging_service_role_key
# Optional public Pixel ID. Keep empty until consent and a synthetic staging browser test are approved.
NEXT_PUBLIC_META_PIXEL_ID=

# Required comparison values for any write-enabled test.
# The target ref must exactly equal the project subdomain in NEXT_PUBLIC_SUPABASE_URL.
FANMIND_TARGET_SUPABASE_PROJECT_REF=stagingprojectref
FANMIND_PRODUCTION_SUPABASE_PROJECT_REF=productionprojectref
FANMIND_ENABLE_NON_PRODUCTION_WRITES=false
FANMIND_NON_PRODUCTION_WRITE_ACK=

# Staging uses Stripe test mode only.
STRIPE_SECRET_KEY=sk_test_replace_with_staging_key
STRIPE_WEBHOOK_SECRET=whsec_replace_with_staging_secret
FANMIND_ENABLE_REFERRAL_BILLING=false
FANMIND_REFERRAL_SANDBOX_ACK=
FANMIND_REFERRAL_RECONCILE_SECRET=replace_with_staging_random_secret

# Public/demo/automation switches stay off until each staging test is approved.
FANMIND_PUBLIC_DEMO_ENABLED=false
FANMIND_ENABLE_TELEGRAM_SEND=false
FANMIND_OPERATIONS_MONITOR_ENABLED=false
FANMIND_OPERATIONS_EMAIL_ENABLED=false
FANMIND_SERVER_ERROR_TRACKING_ENABLED=false
FANMIND_SERVER_ERROR_EMAIL_ENABLED=false
FANMIND_ENABLE_ISOLATED_RELEASE_DEPLOY=false

# Use synthetic test users and contacts only.
FANMIND_ADMIN_EMAILS=staging-admin@example.com
OPENAI_API_KEY=replace_with_staging_limited_key
RESEND_API_KEY=
FANMIND_NOTIFICATION_FROM="FanMind Staging <noreply@staging.fanmind.example>"
