# Supabase Public API configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key

# Server-only OpenAI key
OPENAI_API_KEY=your_openai_key

# Server-only Meta webhook test connector
META_WEBHOOK_VERIFY_TOKEN=replace_with_meta_webhook_verify_token
# Optional: validates X-Hub-Signature-256 on incoming Meta webhook POST requests.
META_WEBHOOK_APP_SECRET=
# Optional test-mode mapping for receive-only Meta webhook events.
FANMIND_DEFAULT_WORKSPACE_ID_FOR_META_TEST=
FANMIND_DEFAULT_CONTACT_ID_FOR_META_TEST=
