# Supabase Public API configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_key
NEXT_PUBLIC_APP_URL=https://fanmind.ch

# Optional public Meta Pixel configuration. The numeric Pixel ID is not a secret.
# The script remains disabled until explicit marketing consent is granted.
# Leave empty to disable the Pixel completely in this environment.
# In YAML-based CI files quote the full value so it cannot become scientific notation.
NEXT_PUBLIC_META_PIXEL_ID=2069553844439892

# Server-only OpenAI key and AI cost configuration
OPENAI_API_KEY=your_openai_key
# Optional server-side model override. Keep model names server-side and update deliberately.
FANMIND_AI_MODEL=
# Optional server-side estimated AI pricing in minor currency units per 1M tokens.
# Keep current provider prices here, not in client UI copy.
FANMIND_AI_PRICE_INPUT_PER_MILLION_CENTS=
FANMIND_AI_PRICE_OUTPUT_PER_MILLION_CENTS=
# Optional model-specific overrides use normalized model names, e.g. gpt-5.2 -> GPT_5_2.
FANMIND_AI_PRICE_GPT_5_2_INPUT_PER_MILLION_CENTS=
FANMIND_AI_PRICE_GPT_5_2_OUTPUT_PER_MILLION_CENTS=
FANMIND_AI_USAGE_CURRENCY=USD
# Optional soft notice thresholds for the user-facing monthly AI usage page.
# Empty values mean measurement only: no contractual quota, automatic block or billing change.
FANMIND_AI_STANDARD_SOFT_REQUEST_WARNING=
FANMIND_AI_STANDARD_SOFT_TOKEN_WARNING=

# Public temporary demo safety. Secrets are server-only.
# Keep the public demo switch false until the migration, limits, and cleanup job are live-tested.
FANMIND_PUBLIC_DEMO_ENABLED=false
FANMIND_DEMO_RATE_LIMIT_SECRET=replace_with_long_random_secret
FANMIND_DEMO_MAX_PER_IP_10_MIN=1
FANMIND_DEMO_MAX_PER_IP_DAY=10
FANMIND_DEMO_MAX_PER_BROWSER_DAY=5
FANMIND_DEMO_MAX_ACTIVE=50
FANMIND_DEMO_MAX_AI_REQUESTS=5
FANMIND_DEMO_MAX_CONTACTS=30
FANMIND_DEMO_CLEANUP_SECRET=replace_with_long_random_cleanup_secret
FANMIND_DEMO_CLEANUP_LIMIT=25
# Optional Cloudflare Turnstile browser widget plus mandatory server-side token validation.
# Keep required=false until both keys are configured and the widget has been tested.
FANMIND_REQUIRE_TURNSTILE_FOR_PUBLIC_DEMO=false
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Server-only Facebook Messenger webhook and OAuth connector
FACEBOOK_WEBHOOK_VERIFY_TOKEN=replace_with_facebook_webhook_verify_token
FACEBOOK_APP_ID=replace_with_facebook_app_id
FACEBOOK_APP_SECRET=replace_with_facebook_app_secret
FACEBOOK_REDIRECT_URI=https://your-domain.example/api/integrations/facebook/callback
# Legacy META_* names are still accepted as fallback during migration.
META_WEBHOOK_VERIFY_TOKEN=replace_with_meta_webhook_verify_token
META_WEBHOOK_APP_SECRET=replace_with_meta_app_secret
META_APP_ID=replace_with_meta_app_id
META_APP_SECRET=replace_with_meta_app_secret
META_REDIRECT_URI=https://your-domain.example/api/integrations/facebook/callback
FANMIND_APP_URL=https://fanmind.ch
# 32-byte encryption key for page tokens. Use base64 or 64 hex chars. Required for productive Facebook connections.
FANMIND_TOKEN_ENCRYPTION_KEY=replace_with_32_byte_base64_or_hex_key

# Technical webhook diagnostics are privacy-minimized and deleted in bounded batches.
# The worker defaults to a 30-day retention window and never touches CRM or billing data.
FANMIND_WEBHOOK_DIAGNOSTIC_RETENTION_DAYS=30
FANMIND_WEBHOOK_DIAGNOSTIC_DELETE_LIMIT=500

# Local development fallback only. Production webhook routing uses social_connections by page_id.
FANMIND_DEFAULT_WORKSPACE_ID_FOR_META_TEST=
FANMIND_DEFAULT_CONTACT_ID_FOR_META_TEST=
# Server-only Supabase key. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# Dedicated HMAC secret for atomic shared AI/inquiry rate-limit identities.
# Generate at least 32 random bytes. Never expose it to the browser or logs.
FANMIND_SHARED_RATE_LIMIT_SECRET=replace_with_long_random_shared_rate_limit_secret

# Account-deletion request and manual execution controls.
# Requests are accepted through authenticated Web/Mobile routes. Destructive processing is always off by default.
FANMIND_ACCOUNT_DELETION_EXECUTION_ENABLED=false
# Generate at least 32 random bytes. Used only to pseudonymize the completed request after auth-user deletion.
FANMIND_ACCOUNT_DELETION_HASH_SECRET=replace_with_long_random_account_deletion_hash_secret
# Optional internal mailbox for a request notice. The notice contains no email address, user ID, token or customer data.
FANMIND_ACCOUNT_DELETION_TO=kontakt@fanmind.ch

# Server-only Telegram Bot webhook integration. Never expose the real token in the browser.
# Telegram sending is not part of the standard Gerhard demo unless explicitly enabled as a validated pilot.
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_WEBHOOK_SECRET=replace_with_telegram_webhook_secret
# Disabled by default; only enable for explicitly approved admin/pilot checks.
FANMIND_ENABLE_TELEGRAM_SEND=false
FANMIND_DEFAULT_WORKSPACE_ID_FOR_TELEGRAM_TEST=

# Server-only Stripe billing configuration. Never expose real secrets to the browser.
# Default: small_business (no Stripe automatic tax calculation). Use stripe_tax only after tax/legal validation.
FANMIND_TAX_MODE=small_business
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PILOT_SETUP=
STRIPE_PRICE_STARTER_SETUP=
STRIPE_PRICE_STARTER_MONTHLY=
# Referral automation updates future subscription invoices only. Enable after migration, Stripe sandbox smoke test, and legal/payment approval.
FANMIND_ENABLE_REFERRAL_BILLING=false
FANMIND_REFERRAL_RECONCILE_SECRET=replace_with_long_random_reconcile_secret
# Required only for an explicit write-enabled referral test on a non-production target.
# Never set this acknowledgement in Production.
FANMIND_REFERRAL_SANDBOX_ACK=
# Live-only internal/Beta 1 €/day Stripe recurring price. Public registration only when FANMIND_ENABLE_PUBLIC_DAILY_TEST_PLAN=true.
FANMIND_ENABLE_PUBLIC_DAILY_TEST_PLAN=false
STRIPE_PRICE_INTERNAL_DAILY_TEST=

# Server-only comma-separated list of platform admin emails. Set real values only in .env.production.
FANMIND_ADMIN_EMAILS=admin@example.com,admin2@example.com

# Optional server-only transactional email for pilot inquiries and account-deletion notices.
RESEND_API_KEY=
FANMIND_NOTIFICATION_FROM="FanMind <noreply@fanmind.ch>"
FANMIND_INQUIRY_TO=kontakt@fanmind.ch
