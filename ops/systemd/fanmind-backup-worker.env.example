# Copy to /etc/fanmind-backup/worker.env with mode 600, root:root. Do not commit real values.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
FANMIND_BACKUP_WORKER_ID=fanmind-prod-01-backup-worker
FANMIND_BACKUP_ROOT=/var/backups/fanmind
FANMIND_BACKUP_PUBLIC_KEY_FILE=/etc/fanmind-backup/recipient.txt
FANMIND_BACKUP_DB_HOST=
FANMIND_BACKUP_DB_PORT=5432
FANMIND_BACKUP_DB_NAME=postgres
FANMIND_BACKUP_DB_USER=
FANMIND_BACKUP_PGPASSFILE=/etc/fanmind-backup/pgpass
FANMIND_PG_DUMP_BIN=/usr/lib/postgresql/17/bin/pg_dump
FANMIND_PG_RESTORE_BIN=/usr/lib/postgresql/17/bin/pg_restore
FANMIND_BACKUP_OFFSITE_ENABLED=false
FANMIND_BACKUP_RCLONE_REMOTE=
FANMIND_BACKUP_RCLONE_CONFIG=/etc/fanmind-backup/rclone.conf
FANMIND_BACKUP_REMOTE_PATH=fanmind/production
