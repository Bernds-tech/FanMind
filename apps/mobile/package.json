{
  "name": "@fanmind/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "doctor": "expo-doctor",
    "boundary": "node scripts/check-boundary.mjs",
    "export:android": "expo export --platform android --output-dir dist-android",
    "check": "npm run typecheck && npm run doctor && npm run boundary"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.5",
    "expo": "~57.0.8",
    "expo-clipboard": "~57.0.0",
    "expo-constants": "~57.0.7",
    "expo-linking": "~57.0.4",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-status-bar": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "expo-doctor": "1.20.1",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
