{
  "expo": {
    "name": "FanMind",
    "slug": "fanmind-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "fanmind",
    "userInterfaceStyle": "dark",
    "plugins": [
      "expo-router",
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true,
          "faceIDPermission": "FanMind schützt deine sichere App-Sitzung."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ch.fanmind.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "ch.fanmind.app",
      "adaptiveIcon": {
        "backgroundColor": "#06142c"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "extra": {
      "product": "FanMind Mobile",
      "website": "https://fanmind.ch"
    }
  }
}
